# .env.example — template for secrets. Copy to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.
#
# CRITICAL: do NOT set ANTHROPIC_API_KEY here or anywhere in the runtime
# environment. The LLM step runs through Claude Code under the Max
# subscription; setting that key silently bills the pay-as-you-go API instead.

# FRED economic data (free key: https://fredaccount.stlouisfed.org/apikeys)
FRED_API_KEY=your_fred_api_key_here

# Finnhub price-data fallback (free tier: https://finnhub.io/dashboard)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Gmail send (use a Gmail App Password, not your account password:
# https://myaccount.google.com/apppasswords)
GMAIL_ADDRESS=gudziunastimas@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here
